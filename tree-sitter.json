{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "dockerfile",
      "camelcase": "Dockerfile",
      "scope": "source.dockerfile",
      "path": ".",
      "file-types": [
        "Dockerfile",
        "dockerfile",
        "docker",
        "Containerfile",
        "container"
      ],
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "metadata": {
    "version": "0.4.1",
    "license": "ISC",
    "description": "A tree-sitter module for the Dockerfile grammar",
    "authors": [
      {
        "name": "hiziri",
        "email": "meirvg+dev@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/4hiziri/tree-sitter-dockerfile-fix"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
